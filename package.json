{
  "name": "friends-voice-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "api:dev": "node backend/server.js",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "desktop:build:win": "npm run build && electron-builder --publish never --win portable nsis",
    "desktop:build:win:installer": "npm run build && electron-builder --publish never --win nsis",
    "desktop:build:win:publish": "npm run build && electron-builder --publish always --win portable nsis",
    "desktop:build:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "livekit-client": "^2.17.2",
    "livekit-server-sdk": "^2.15.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "ai.friends.voice",
    "productName": "Friends Voice",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cany123rus",
        "repo": "FriendVoise"
      }
    ],
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Friends-Voice-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Friends-Voice-Portable-${version}.${ext}"
    }
  }
}
